{% macro alert(text, className) %}
    <div class="yt-alert yt-alert-default {{ className }}">
        <div class="yt-alert-icon"><img src="//s.ytimg.com/yt/img/pixel-vfl3z5WfW.gif" class="icon master-sprite" alt="Alert icon" /></div>
        <button class="close yt-uix-close" data-close-parent-class="yt-alert"type="button"><span class="yt-uix-button-content">Close</span></button>
        <div class="yt-alert-content">
            <span class="yt-alert-vertical-trick"></span>
            <div class="yt-alert-message">{{ text }}</div>
        </div>
    </div>
{% endmacro %}
