{% import '2012/_macros.html.j2' as macros %}
{% extends "2012/_root.html.j2" %}

{% block title %}{{ search_query }} - YouTube{% endblock %}

{% block core_css %}
{# <link id="www-core-css" rel="stylesheet" href="https://s.ytimg.com/yt/cssbin/www-refresh-vfl1B0Nkn.css"> #}
<link id="www-core-css" rel="stylesheet" href="https://s.ytimg.com/yt/cssbin/www-refresh-datauri-vflKEEucy.css">
{% endblock %}

{% block extra_css %}
<style>
    /* Layout fixes for playlist search results */
    .result-item.result-playlist-experiment .thumb-container .result-item-thumb {
        float: left !important;
        height: 80px !important;
    }
    .playlist-rec-video-thumbs .playlist-thumb-0 {
        top: 0 !important;
        left: 0 !important;
    }
    .playlist-rec-video-thumbs .playlist-thumb-1,
    .playlist-rec-video-thumbs .playlist-thumb-2 {
        top: 3px !important;
        left: 3px !important;
    }
    .result-item .facets {
        margin-bottom: 0;
    }
    .result-item {
        cursor: default; /* remove pointer from non-link areas */
    }
    .result-item-playlist-header h3 {
        line-height: 15px;
    }
    .tiny-video-icon {
        margin-top: 4px;
    }
</style>
{% endblock %}

{% block alerts %}
<noscript>
{{ macros.alert('Hello, you seem to have JavaScript turned off. Please enable it to see search results properly.', 'yt-alert-error') }}
</noscript>
{% endblock %}

{% block content %}

<div id="search-header">
    <div id="search-header-inner">
        <p class="num-results">About <strong>{{ format_number_thousands(search_results['estimated_results']) }}</strong> results</p>
        <h2>Search results for <strong class="query">{{ search_query }}</strong></h2>
    </div>
    <hr class="horizontal-rule" />
</div>

<div id="search-refinements">
    <div id="search-section-header" class="ytg-box">
        <div id="search-option-expander" class="floatL" onclick="yt.www.search.toggleToolbelt()">
            <button
                type="button"
                class="yt-uix-button yt-uix-button-text"
                onclick="return false;"
                data-button-toggle="true"
                data-button-menu-id="some-nonexistent-menu"
                data-button-action=""
                role="button"
            >
                <span class="yt-uix-button-content">Filter</span>
                <img class="yt-uix-button-arrow" src="//s.ytimg.com/yt/img/pixel-vfl3z5WfW.gif" alt="" />
            </button>
        </div>

        <div class="clear"></div>
        <div id="toolbelt-top" class="hid">
            <div id="toolbelt-container">
                <div class="search-option-box search-option-box-first">
                    <div class="search-option-label">Result type:</div>
                    <div class="search-option">All</div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;uni=3">
                            Videos
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=search_users&amp;search_query=Ernie+%26+Bert&amp;uni=3">
                            Channels
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=search_playlists&amp;search_query=Ernie+%26+Bert&amp;uni=3">
                            Playlists
                        </a>
                    </div>
                </div>

                <div class="search-option-box">
                    <div class="search-option-label">Sort by:</div>
                    <div class="search-option">Relevance</div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;search_sort=video_date_uploaded&amp;uni=3">
                            Upload date
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;search_sort=video_view_count&amp;uni=3">
                            View count
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;search_sort=video_avg_rating&amp;uni=3">
                            Rating
                        </a>
                    </div>
                </div>

                <div class="search-option-box">
                    <div class="search-option-label">Upload date:</div>
                    <div class="search-option">Anytime</div>

                    <div class="search-option">
                        <a href="/results?uploaded=d&amp;search_type=videos&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            Today
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?uploaded=w&amp;search_type=videos&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            This week
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?uploaded=m&amp;search_type=videos&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            This month
                        </a>
                    </div>
                </div>

                <div class="search-option-box">
                    <div class="search-option-label">Categories:</div>
                    <div class="search-option">All</div>
                    <div class="search-option">
                        <a href=" /results?search_type=videos&amp;search_category=27&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            Education
                        </a>
                    </div>
                    <div class="search-option">
                        <a href=" /results?search_type=videos&amp;search_category=22&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            People &amp; Blogs
                        </a>
                    </div>
                    <div class="search-option">
                        <a href=" /results?search_type=videos&amp;search_category=10&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            Music
                        </a>
                    </div>
                    <div class="search-option">
                        <a href=" /results?search_type=videos&amp;search_category=17&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            Sports
                        </a>
                    </div>
                    <div class="search-option">
                        <a href=" /results?search_type=videos&amp;search_category=23&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            Comedy
                        </a>
                    </div>
                </div>

                <div class="search-option-box">
                    <div class="search-option-label">Duration:</div>
                    <div class="search-option">All</div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;search_duration=short&amp;uni=3">
                            Short (~4 minutes)
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;search_duration=long&amp;uni=3">
                            Long (20~ minutes)
                        </a>
                    </div>
                </div>

                <div class="search-option-box">
                    <div class="search-option-label">Features:</div>
                    <div class="search-option">All</div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;closed_captions=1&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            Closed captions
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;high_definition=1&amp;uni=3">
                            HD (high definition)
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;partner=1&amp;search=tag&amp;uni=3&amp;search_query=Ernie+%26+Bert">
                            Partner videos
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;rental=1&amp;uni=3">
                            Rental
                        </a>
                    </div>

                    <div class="search-option">
                        <a href="/results?search_type=videos&amp;search_query=Ernie+%26+Bert&amp;search=tag&amp;uni=3&amp;webm=1">
                            WebM
                        </a>
                    </div>
                </div>

                <div class="clear"></div>
            </div>
        </div>
    </div>
</div>

<div class="horizontal-rule">
    <span class="first"></span>
    <span class="second"></span>
    <span class="third"></span>
</div>

<div id="search-base-div">
    <div id="search-main" class="ytg-4col new-snippets">
        <div id="results-main-content">
            <div id="search-results">

                {% for item in search_results['entries'] %}
                {% if item['type'] == 'video' %}
                <div class="result-item yt-uix-tile yt-tile-default *sr">
                    <div class="thumb-container">
                        <a
                            href="/watch?v={{ item['id'] }}"
                            class="ux-thumb-wrap contains-addto result-item-thumb"
                        >
                            <span class="video-thumb ux-thumb ux-thumb-128">
                                <span class="clip">
                                    <span class="clip-inner">
                                        <img
                                            alt="Thumbnail"
                                            src="//i4.ytimg.com/vi/{{ item['id'] }}/default.jpg"
                                        />
                                        <span class="vertical-align"></span>
                                    </span>
                                </span>
                            </span>
                            <span class="video-time">{{ item['length_text'] }}</span>

                            <button
                                onclick="return false;"
                                title="Watch Later"
                                type="button"
                                class="addto-button video-actions addto-watch-later-button-sign-in yt-uix-button yt-uix-button-default yt-uix-button-short yt-uix-tooltip"
                                data-button-menu-id="shared-addto-watch-later-login"
                                data-video-ids="{{ item['id'] }}"
                                data-feature="thumbnail"
                                role="button"
                            >
                                <img
                                    class="yt-uix-button-icon yt-uix-button-icon-addto"
                                    src="//s.ytimg.com/yt/img/pixel-vfl3z5WfW.gif"
                                    alt=""
                                /><span class="yt-uix-button-content">
                                    <span class="addto-label">Add to</span>
                                </span><img
                                    class="yt-uix-button-arrow"
                                    src="//s.ytimg.com/yt/img/pixel-vfl3z5WfW.gif"
                                    alt=""
                                />
                            </button>
                        </a>
                    </div>
                    <div class="result-item-main-content">
                        <h3 id="video-long-title-{{ item['id'] }}">
                            <a
                                href="/watch?v={{ item['id'] }}"
                                class="yt-uix-tile-link"
                                dir="ltr"
                                title="{{ item['title'] }}"
                            >
                                {{ item['title'] }}
                            </a>
                        </h3>

                        <p
                            id="video-description-{{ item['id'] }}"
                            class="description"
                        >
                            {{ item['description'] }}
                        </p>

                        <p class="facets">
                            <span class="username-prepend">by</span>
                            <a
                                href="/channel/{{ item['channel_id'] }}"
                                class="yt-user-name"
                                dir="ltr"
                            >
                                {{ item['channel_name'] }}
                            </a>

                            <span class="metadata-separator">|</span>
                            <span class="date-added">{{ item['published_text'] }}</span>
                            <span class="metadata-separator">|</span>
                            <span class="viewcount">{{ item['viewcount_text'] }}</span>
                        </p>
                    </div>
                </div>
                {% elif item['type'] == 'playlist' %}
                <div class="result-item yt-uix-tile yt-tile-default result-playlist-experiment">
                    <div class="thumb-container">
                        <a
                            href="/playlist?list={{ item['id'] }}"
                            class="thumb-experimental-playlist ux-thumb-wrap result-item-thumb"
                            dir="ltr"
                            title="{{ item['title'] }}"
                        >
                            <span class="playlist-rec-video-thumbs">
                                {% if item['playlist_entries'] %}
                                <span class="playlist-thumb-0">
                                    <span class="video-thumb ux-thumb ux-thumb-128">
                                        <span class="clip">
                                            <span class="clip-inner">
                                                <img
                                                    src="//i4.ytimg.com/vi/{{ item['playlist_entries'][0]['id'] }}/default.jpg"
                                                    alt="Thumbnail"
                                                />
                                                <span class="vertical-align"></span>
                                            </span>
                                        </span>
                                    </span>
                                </span>
                                {% if item['playlist_entries']|length > 1 %}
                                <span class="playlist-thumb-1">
                                    <span class="video-thumb ux-thumb ux-thumb-128">
                                        <span class="clip">
                                            <span class="clip-inner">
                                                <img
                                                    src="//i4.ytimg.com/vi/{{ item['playlist_entries'][1]['id'] }}/default.jpg"
                                                    alt="Thumbnail"
                                                />
                                                <span class="vertical-align"></span>
                                            </span>
                                        </span>
                                    </span>
                                </span>
                                {% endif %}
                                {% elif item['thumbnail_url'] %}
                                <span class="playlist-thumb-0">
                                    <span class="video-thumb ux-thumb ux-thumb-128">
                                        <span class="clip">
                                            <img
                                                src="{{ item['thumbnail_url'] }}"
                                                alt="{{ item['title'] }}"
                                            />
                                        </span>
                                    </span>
                                </span>
                                {% endif %}
                            </span>
                        </a>
                    </div>
                    <div class="result-item-main-content">
                        <div class="result-item-playlist-header">
                            <h3
                                id="playlist-long-title-{{ item['id'] }}"
                                class="playlist-long-title"
                            >
                                <a
                                    href="/playlist?list={{ item['id'] }}"
                                    class="yt-uix-tile-link"
                                    dir="ltr"
                                    title="{{ item['title'] }}"
                                >
                                    {{ item['title'] }}
                                </a>
                            </h3>
                            <span class="byline">
                                <span class="username-prepend">by</span>
                                <a
                                    href="/channel/{{ item['channel_id'] }}"
                                    class="yt-user-name"
                                    dir="ltr"
                                >
                                    {{ item['channel_name'] }}
                                </a>
                            </span>
                            <span class="yt-badge-std">Playlist</span>
                        </div>

                        {% if item['playlist_entries'] %}
                        <div class="playlist-videos">
                            <ul>
                                {% for video in item['playlist_entries'] %}
                                <li class="playlist-video">
                                    <span class="tiny-video-icon floatL"></span>
                                    <a
                                        href="/watch?v={{ video['id'] }}&amp;list={{ item['id'] }}"
                                        class="playlist-detail-title"
                                        dir="ltr"
                                        title="{{ video['title'] }}"
                                    >
                                        {{ video['title'] }}
                                    </a>
                                    {% if video['length_text'] %}
                                    <span class="playlist-video-length">
                                        {{ video['length_text'] }}
                                    </span>
                                    {% endif %}
                                </li>
                                {% endfor %}
                            </ul>
                        </div>
                        {% endif %}

                        <p class="facets playlist-facets">
                            <span class="playlist-video-count">{{ item['video_count'] }}</span>
                        </p>
                    </div>
                </div>
                {% elif item['type'] == 'channel' %}
                <div class="result-item yt-uix-tile yt-tile-default channel">
                    <div class="thumb-container">
                        <a
                            href="/channel/{{ item['channel_id'] }}"
                            class="ux-thumb-wrap result-item-thumb"
                            dir="ltr"
                            title="{{ item['title'] }}"
                        >
                            <span class="user-thumb-large ux-thumb ux-thumb-profile-77">
                                <span class="clip">
                                    <span class="clip-inner">
                                        <span class="profile-centering-wrap">
                                            <img
                                                src="{{ item['thumbnail_url'] }}"
                                                alt="{{ item['title'] }}"
                                            />
                                        </span>
                                        <span class="vertical-align"></span>
                                    </span>
                                </span>
                            </span>
                        </a>
                    </div>
                    <div class="result-item-main-content channel-main-content">
                        <h3
                            id="channel-long-title-{{ item['id'] }}"
                            class="channel-long-title"
                        >
                            <a
                                href="/channel/{{ item['channel_id'] }}"
                                class="yt-uix-tile-link"
                                dir="ltr"
                                title="{{ item['title'] }}"
                            >
                                {{ item['title'] }}
                            </a>
                        </h3>

                        {% if item['description'] %}
                        <p
                            id="channel-description-{{ item['id'] }}"
                            class="description channel-description"
                        >
                            {{ item['description'] }}
                        </p>
                        {% endif %}

                        <p class="facets channel-facets">
                            <span class="channel-video-count">{{ item['video_count'] }}</span>
                        </p>
                    </div>
                </div>
                {% endif %}
                {% endfor %}

            </div>
        </div>
    </div>

    <div id="search-pva-content">
    </div>
</div>


<div id="search-footer-box" class="searchFooterBox">
    <div class="yt-uix-pager" role="navigation">

        {% if search_page.prev %}
        <a
            href="/results?search_query={{ search_query_url }}&amp;page={{ search_page.prev }}"
            class="yt-uix-button yt-uix-pager-prev yt-uix-pager-button"
            data-page="{{ search_page.prev }}"
        >
            <span class="yt-uix-button-content">« Previous</span>
        </a>
        &nbsp;
        {% endif %}

        {% for page in search_page.range %}
        <a
            href="/results?search_query={{ search_query_url }}&amp;page={{ page }}"
            class="yt-uix-button yt-uix-pager-page-num yt-uix-pager-button {{ 'yt-uix-button-toggled' if page == search_results['page'] else '' }}"
            data-page="{{ page }}"
            aria-label="Go to page {{ page }}"
        >
            <span class="yt-uix-button-content">{{ page }}</span>
        </a>
        &nbsp;

        {% endfor %}

        {% if search_page.next %}
        <a
            href="/results?search_query={{ search_query_url }}&amp;page={{ search_page.next }}"
            class="yt-uix-button yt-uix-pager-next yt-uix-pager-button"
            data-page="{{ search_page.next }}"
        >
            <span class="yt-uix-button-content">Next »</span>
        </a>
        &nbsp;
        {% endif %}
    </div>
</div>

<div class="clear"></div>

{% endblock %}