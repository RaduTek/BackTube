    {% if videos_feed %}
    <div class="single-playlist channel-module yt-uix-c3-module-container" style="overflow: visible;">
    <div class="module-view single-playlist-view-module">
        <div class="blogger-playall">
            <a class="yt-playall-link yt-playall-link-default" href="#">
                <img class="small-arrow" src="//s.ytimg.com/yt/img/pixel-vfl3z5WfW.gif" alt="">
                Play all
            </a>
        </div>

        <div class="playlist-info">
            <h2>{{ videos_feed.title }}</h2>
            {# <span class="blogger-video-count">1-10 of 266</span> #}
            <div class="horizontal-rule "><span class="first"></span><span class="second"></span><span class="third"></span></div>
        </div>
    
        <ul class="gh-single-playlist">
        {% for item in videos_feed['items'][:10] %}
            <li class="blogger-video">
                <span class="video tile">
                    <a href="{{ item.url }}"
                        class="tile-link-block">
                        <span class="ux-thumb-wrap contains-addto">
                            <span class="video-thumb ux-thumb ux-thumb-200">
                                <span class="clip">
                                    <span class="clip-inner">
                                        <img src="{{ video_thumbnail_url(item.id, True) }}" alt="Thumbnail" />
                                        <span class="vertical-align"></span>
                                    </span>
                                </span>
                            </span>
                            <span class="video-time">{{ item.length_text }}</span>
                            {{ macros.watch_later_button(item) }}
                        </span>
                        <span class="video-item-content">
                            <span class="video-overview">
                                <span class="title video-title" title="{{ item.title }}">{{ item.title }}</span>
                            </span>
                            <span class="video-details">
                                {% if item.channel_name -%}
                                <span class="video-owner">{{ item.channel_name }}</span>
                                {%- endif %}
                                <span class="video-view-count">{{ item.viewcount_text }}</span>
                                <span class="video-time-published">{{ item.published_text }}</span>
                                <span class="video-item-description">{{ item.description }}</span>
                            </span>
                        </span>
                    </a>
                </span>
            </li>
        {% endfor %}
        </ul>
    </div>
    </div>
    {% endif%}

{% endblock %}

